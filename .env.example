# Base de datos Neon (pooler para la app)
DATABASE_URL="postgresql://user:password@host-pooler.neon.tech/neondb?sslmode=require"

# Base de datos Neon (directo para migraciones)
DIRECT_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=require"

# NextAuth
AUTH_SECRET="clave-secreta-aleatoria"
NEXTAUTH_URL="https://tu-dominio.vercel.app"

# Gmail SMTP (recuperación de contraseña)
GMAIL_USER="tu@gmail.com"
GMAIL_APP_PASSWORD="contraseña-de-aplicacion-gmail"

# Resend (emails de notificaciones y cotizaciones) — solo en Vercel env vars
RESEND_API_KEY="re_..."

# Cron jobs — solo en Vercel env vars
CRON_SECRET="clave-secreta-cron"

# Admin — clave para crear nuevos tenants
ADMIN_REGISTRO_SECRET="clave-secreta-admin"
