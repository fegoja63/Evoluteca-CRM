# Copia este archivo a .env y completa los valores
# cp .env.example .env

# Cadena de conexión de PostgreSQL (ej: Supabase Transaction Pooler)
DATABASE_URL="postgresql://usuario:contraseña@host:5432/nombre_db"

# Secreto para NextAuth — genera uno con: openssl rand -base64 32
AUTH_SECRET="tu-secreto-aqui"

# URL base de la app (no cambiar para desarrollo local)
NEXTAUTH_URL="http://localhost:3000"
