// Evoluteca CRM — Esquema de base de datos
// Sprint 1: Fundación y autenticación
// Los modelos de sprints futuros están comentados como referencia.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RolUsuario {
  ADMINISTRADOR
  GERENTE
  COMERCIAL
}

// Rate limiting de ventana fija persistido en Postgres — evita depender de
// Redis/Upstash solo para esto. Cada fila es una "clave" (ej. login:email,
// ip:forgot-password) con un contador que se reinicia cuando expira la
// ventana. El volumen de filas es bajo (una por identidad activa) y se
// autolimpia al expirar cada ventana, así que no hace falta un cron de purga.
model RateLimit {
  clave         String   @id
  intentos      Int      @default(1)
  ventanaInicio DateTime @default(now())

  @@map("rate_limits")
}

// Cada empresa cliente de Evoluteca es un "tenant" aislado.
// Todas las tablas de negocio (empresas, contactos, oportunidades...)
// llevan tenantId para garantizar separación de datos entre clientes.
model Tenant {
  id                String   @id @default(uuid())
  nombre            String
  slug              String   @unique
  plan              String   @default("arranque") // arranque | empresa | corporativo
  activo            Boolean  @default(true)
  creadoEn          DateTime @default(now())
  modulos           Json     @default("{}")
  logoUrl           String?
  emailsActivos     Boolean  @default(true)
  // Cuerpo/condiciones que el tenant define una vez y se repiten en TODAS sus
  // cotizaciones (PDF y link público): array de { titulo, contenido }. Ej:
  // "Sobre nosotros", "Alcance", "Condiciones comerciales", "Condiciones
  // legales", "Términos y plazos". null/[] = se usan las condiciones por
  // defecto del sistema (no rompe cotizaciones de tenants que no lo configuren).
  cuerpoCotizacion  Json?
  apiKeyLeads       String?  @unique
  // Tope de usuarios activos según el plan contratado (null = sin límite).
  // Lo controla exclusivamente el panel interno de Evoluteca, no el propio
  // tenant — es una palanca de precios, no una preferencia de cuenta.
  limiteUsuarios    Int?
  // Tope de "Resúmenes con IA" por mes (palanca de plan, controlada por el
  // panel interno). null = ilimitado; 0 = IA desactivada; N>0 = tope mensual.
  // Por defecto 100 (plan Pro). El consumo real se lleva en UsoIA.
  limiteResumenesIA Int?     @default(100)

  usuarios             Usuario[]
  empresas             Empresa[]
  contactos            Contacto[]
  oportunidades        Oportunidad[]
  actividades          Actividad[]
  cotizaciones         Cotizacion[]
  funciones            Funcion[]
  espectadores         Espectador[]
  productos            Producto[]
  plantillasCotizacion PlantillaCotizacion[]
  metasVenta           MetaVenta[]
  metasVendedor        MetaVendedor[]
  eventosTimeline      EventoTimeline[]
  expedientes          Expediente[]
  terminosExpediente   TerminoExpediente[]
  eventosExpediente    EventoExpediente[]
  registrosHoras       RegistroHoras[]
  asistencias          Asistencia[]
  salones              Salon[]
  adjuntos             Adjunto[]
  etapasPipeline       EtapaPipeline[]
  usoIA                UsoIA[]
  registrosAuditoria   RegistroAuditoria[]

  @@map("tenants")
}

// Consumo mensual de "Resúmenes con IA" por tenant. Una fila por
// (tenant, periodo "YYYY-MM"). Se incrementa cada vez que se genera un
// resumen exitoso; se usa para hacer cumplir limiteResumenesIA y para
// mostrar el gasto en el panel interno.
model UsoIA {
  id            String   @id @default(uuid())
  tenantId      String
  periodo       String // "YYYY-MM"
  cantidad      Int      @default(0)
  tokensEntrada Int      @default(0)
  tokensSalida  Int      @default(0)
  actualizadoEn DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, periodo])
  @@map("uso_ia")
}

model Usuario {
  id               String     @id @default(uuid())
  nombre           String
  email            String     @unique
  passwordHash     String
  rol              RolUsuario @default(COMERCIAL)
  activo           Boolean    @default(true)
  creadoEn         DateTime   @default(now())
  resetToken       String?    @unique
  resetTokenExpiry DateTime?
  aceptoTerminosEn DateTime?
  versionTerminos  String?
  // Orden personalizado del menú lateral: array de hrefs en el orden que el
  // usuario eligió. Los ítems no listados aquí (nuevos módulos, etc.) se
  // agregan al final en su orden por defecto.
  ordenMenu        Json?
  // Token secreto y revocable para suscribir la agenda personal a un calendario
  // externo (Google/Outlook/Apple) vía /api/calendario/{token}.ics. null =
  // sin suscripción activa. El feed es de solo lectura y solo expone las
  // actividades que el usuario ya puede ver según su rol.
  tokenCalendario  String?    @unique

  // --- Verificación en dos pasos (TOTP, opcional por usuario) ---
  // Secreto compartido con la app de autenticación (Google Authenticator y
  // similares). Se guarda desde que el usuario empieza a activarla, pero no
  // cuenta hasta que confirma con un código válido: si no, un fallo a media
  // activación lo dejaría fuera de su propia cuenta.
  totpSecret       String?
  totpActivadoEn   DateTime?
  // Códigos de un solo uso para entrar si pierde el teléfono. Se guardan
  // hasheados con bcrypt, igual que la contraseña: en claro serían una
  // segunda contraseña escrita en la base de datos.
  codigosRespaldo  String[]   @default([])

  tenantId             String
  tenant               Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  metasVendedor        MetaVendedor[]
  registrosHoras       RegistroHoras[]
  actividadesAsignadas Actividad[]     @relation("ActividadResponsable")

  @@index([tenantId])
  @@map("usuarios")
}

model Empresa {
  id          String    @id @default(uuid())
  nombre      String
  email       String?
  sector      String?
  sitioWeb    String?
  telefono    String?
  notas       String?
  // Condiciones comerciales propias de este cliente (forma de pago, plazos,
  // cláusulas negociadas). Se precargan al crear una cotización para él y
  // quedan editables en cada cotización.
  condicionesComerciales String?
  etiquetas   String[]  @default([])
  extras      Json?
  creadoEn    DateTime  @default(now())
  creadoBy    String?
  eliminadoEn DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactos       Contacto[]
  oportunidades   Oportunidad[]
  actividades     Actividad[]
  cotizaciones    Cotizacion[]
  eventosTimeline EventoTimeline[]
  expedientes     Expediente[]
  adjuntos        Adjunto[]

  @@index([tenantId])
  @@index([tenantId, creadoEn])
  @@index([tenantId, eliminadoEn])
  @@map("empresas")
}

model Contacto {
  id          String    @id @default(uuid())
  nombre      String
  email       String?
  telefono    String?
  cargo       String?
  notas       String?
  extras      Json?
  creadoEn    DateTime  @default(now())
  eliminadoEn DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  segmento String? // INDIVIDUAL | GRUPO | EMPRESA | COLEGIO

  empresaId       String?
  empresa         Empresa?         @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  oportunidades   Oportunidad[]
  actividades     Actividad[]
  cotizaciones    Cotizacion[]
  eventosTimeline EventoTimeline[]
  adjuntos        Adjunto[]

  @@index([tenantId])
  @@index([tenantId, creadoEn])
  @@index([tenantId, eliminadoEn])
  @@map("contactos")
}

enum EtapaOportunidad {
  PROSPECTO
  CALIFICADO
  PROPUESTA
  NEGOCIACION
  GANADA
  PERDIDA
}

model Oportunidad {
  id            String           @id @default(uuid())
  titulo        String
  valor         Decimal?         @db.Decimal(12, 2)
  costo         Decimal?         @db.Decimal(12, 2)
  etapa         EtapaOportunidad @default(PROSPECTO)
  motivoPerdida String?
  fechaEvento   DateTime?
  horaInicio    String?
  horaFin       String?
  fechaCierre   DateTime?
  sede          String?
  origenLead    String?
  segmento      String?
  recurrente    Boolean?
  notas         String?
  extras        Json?
  probabilidad  Int?             @default(50)
  creadoEn      DateTime         @default(now())
  creadoBy      String?
  eliminadoEn   DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  empresaId String?
  empresa   Empresa? @relation(fields: [empresaId], references: [id], onDelete: SetNull)

  contactoId String?
  contacto   Contacto? @relation(fields: [contactoId], references: [id], onDelete: SetNull)

  salonId String?
  salon   Salon?  @relation(fields: [salonId], references: [id], onDelete: SetNull)

  actividades  Actividad[]
  cotizaciones Cotizacion[]
  cambiosEtapa CambioEtapa[]
  adjuntos     Adjunto[]

  @@index([tenantId])
  @@index([tenantId, creadoEn])
  @@index([tenantId, etapa])
  @@index([tenantId, eliminadoEn])
  @@index([salonId, fechaEvento])
  @@map("oportunidades")
}

// Archivos adjuntos (contratos, cédulas, fotos, etc.) guardados como base64
// directo en la fila, igual que Tenant.logoUrl — sin servicio de storage externo.
// Cada adjunto pertenece a exactamente una entidad (empresa, contacto u oportunidad).
model Adjunto {
  id       String   @id @default(uuid())
  nombre   String
  tipo     String
  tamano   Int
  datos    String
  creadoEn DateTime @default(now())
  creadoBy String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  empresaId String?
  empresa   Empresa? @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  contactoId String?
  contacto   Contacto? @relation(fields: [contactoId], references: [id], onDelete: Cascade)

  oportunidadId String?
  oportunidad   Oportunidad? @relation(fields: [oportunidadId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([empresaId])
  @@index([contactoId])
  @@index([oportunidadId])
  @@map("adjuntos")
}

// Permite a cada tenant renombrar y reordenar las 6 etapas del pipeline sin
// tocar los valores guardados en Oportunidad.etapa (siguen siendo el enum
// EtapaOportunidad de siempre) — "key" es ese valor fijo, "nombre"/"orden"
// son lo único personalizable. Así el Dashboard, Reportes y el cron de
// alertas (que comparan por key literal, ej. o.etapa === "GANADA") no
// necesitan cambiar: solo la UI del Pipeline muestra el nombre/orden custom.
model EtapaPipeline {
  id     String  @id @default(uuid())
  key    String // PROSPECTO | CALIFICADO | PROPUESTA | NEGOCIACION | GANADA | PERDIDA
  nombre String
  orden  Int
  // Solo las 4 etapas intermedias se pueden ocultar, y solo si no tienen
  // oportunidades asignadas (se valida en la API) — GANADA/PERDIDA nunca.
  oculta Boolean @default(false)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("etapas_pipeline")
}

model CambioEtapa {
  id             String   @id @default(uuid())
  etapaAnterior  String
  etapaNueva     String
  creadoEn       DateTime @default(now())
  creadoBy       String?
  creadoByNombre String?

  oportunidadId String
  oportunidad   Oportunidad @relation(fields: [oportunidadId], references: [id], onDelete: Cascade)

  @@index([oportunidadId])
  @@map("cambios_etapa")
}

enum TipoActividad {
  LLAMADA
  REUNION
  TAREA
  EMAIL
  // Solo se ofrecen en el vertical de teatros/alquileres (módulo funciones o
  // salones); la UI las oculta para el resto de tenants.
  VISITA_COMERCIAL
  VISITA_TECNICA
}

// Estado de avance de una tarea/actividad. Se mantiene sincronizado con el
// booleano `completada` de Actividad: COMPLETADA <-> completada=true; cualquier
// otro estado <-> completada=false. `completada` sigue siendo la fuente que usan
// reportes, exports y crons; `estado` agrega el matiz de "en progreso".
enum EstadoActividad {
  PENDIENTE
  EN_PROGRESO
  COMPLETADA
}

model Actividad {
  id         String          @id @default(uuid())
  tipo       TipoActividad   @default(TAREA)
  titulo     String
  fecha      DateTime
  completada Boolean         @default(false)
  estado     EstadoActividad @default(PENDIENTE)
  notas      String?
  creadoEn   DateTime        @default(now())
  creadoBy   String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Responsable de ejecutar la tarea. Puede ser distinto de creadoBy (quien la
  // creó). Si el usuario se elimina, la tarea queda sin responsable (SetNull).
  responsableId String?
  responsable   Usuario? @relation("ActividadResponsable", fields: [responsableId], references: [id], onDelete: SetNull)

  empresaId String?
  empresa   Empresa? @relation(fields: [empresaId], references: [id], onDelete: SetNull)

  contactoId String?
  contacto   Contacto? @relation(fields: [contactoId], references: [id], onDelete: SetNull)

  oportunidadId String?
  oportunidad   Oportunidad? @relation(fields: [oportunidadId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, fecha])
  @@index([tenantId, responsableId])
  @@map("actividades")
}

enum EstadoCotizacion {
  BORRADOR
  ENVIADA
  ACEPTADA
  RECHAZADA
}

// Modalidad de cobro de la cotización.
// FEE_FIJO: líneas fijas (cantidad × precio) — modelo de eventos/servicios.
// SUCCESS_FEE: honorarios como % del ahorro estimado durante un horizonte de
//   meses (modelo estándar de OLTC: optimización de gasto TIC).
// FEE_MENSUAL: un honorario fijo mensual durante un horizonte de meses
//   (alternativa de OLTC si el cliente no quiere el esquema por ahorro).
enum ModalidadCotizacion {
  FEE_FIJO
  SUCCESS_FEE
  FEE_MENSUAL
}

model Cotizacion {
  id                   String              @id @default(uuid())
  numero               Int                 @default(autoincrement())
  // Consecutivo personalizado del cliente (alfanumérico). Cuando está presente
  // se muestra en lugar del consecutivo automático `numero`; el interno se
  // conserva para orden y búsquedas.
  numeroManual         String?
  estado               EstadoCotizacion    @default(BORRADOR)
  modalidad            ModalidadCotizacion @default(FEE_FIJO)
  // Success fee (SUCCESS_FEE) y fee mensual (FEE_MENSUAL):
  porcentajeHonorarios Decimal?            @db.Decimal(5, 2) // % del ahorro (success fee)
  horizonteMeses       Int? // horizonte en meses (ambas)
  feeMensual           Decimal?            @db.Decimal(14, 2) // honorario fijo mensual (fee mensual)
  notas                String?
  // Condiciones comerciales de ESTA cotización. Se copian del cliente al crear
  // y pueden ajustarse por cotización; es lo que se muestra en el PDF y el
  // enlace público (separado de las notas/observaciones).
  condicionesComerciales String?
  fechaEvento          DateTime?
  sede                 String?
  fechaValidez         DateTime?
  tokenPublico         String?             @unique
  motivoRechazo        String?
  impuestoNombre       String?
  impuestoPorcentaje   Decimal?            @db.Decimal(5, 2)
  impuesto2Nombre      String?
  impuesto2Porcentaje  Decimal?            @db.Decimal(5, 2)
  horaInicio           String?
  horaFin              String?
  creadoEn             DateTime            @default(now())
  eliminadoEn          DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  empresaId String?
  empresa   Empresa? @relation(fields: [empresaId], references: [id], onDelete: SetNull)

  contactoId String?
  contacto   Contacto? @relation(fields: [contactoId], references: [id], onDelete: SetNull)

  oportunidadId String?
  oportunidad   Oportunidad? @relation(fields: [oportunidadId], references: [id], onDelete: SetNull)

  salonId String?
  salon   Salon?  @relation(fields: [salonId], references: [id], onDelete: SetNull)

  items        ItemCotizacion[]
  lineasAhorro LineaAhorro[]

  @@index([tenantId])
  @@index([tenantId, creadoEn])
  @@index([tenantId, eliminadoEn])
  @@index([salonId, fechaEvento])
  @@map("cotizaciones")
}

model ItemCotizacion {
  id          String  @id @default(uuid())
  descripcion String
  cantidad    Int     @default(1)
  precioUnit  Decimal @db.Decimal(12, 2)

  cotizacionId String
  cotizacion   Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)

  @@index([cotizacionId])
  @@map("items_cotizacion")
}

// Línea de ahorro estimado por área de gasto (modalidad SUCCESS_FEE).
// El valor estimado del contrato = Σ(ahorroEstimadoMensual) × % honorarios ×
// horizonte de meses. Es una ESTIMACIÓN al cotizar; el ahorro real se mide
// mes a mes tras ganar (fuera del alcance de esta fase).
model LineaAhorro {
  id                    String  @id @default(uuid())
  area                  String // ej. "Telecomunicaciones", "Energía"
  gastoBaseMensual      Decimal @db.Decimal(14, 2)
  ahorroEstimadoMensual Decimal @db.Decimal(14, 2)

  cotizacionId String
  cotizacion   Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)

  @@index([cotizacionId])
  @@map("lineas_ahorro")
}

// Registro de errores en producción (monitoreo propio, sin terceros). Lo llena
// el capturador del cliente (error boundary + window.onerror) y se ve desde el
// panel interno de Evoluteca. Sin relación a Tenant (se conserva el histórico
// aunque el tenant se elimine y sirve incluso sin sesión válida).
model ErrorLog {
  id           String   @id @default(uuid())
  mensaje      String
  stack        String?
  url          String?
  tipo         String   @default("client") // client | unhandledrejection | boundary
  tenantId     String?
  tenantNombre String?
  usuarioEmail String?
  userAgent    String?
  creadoEn     DateTime @default(now())

  @@index([creadoEn])
  @@map("error_logs")
}

// Registro de auditoría: quién hizo qué, cuándo y sobre qué.
//
// La papelera y la línea de tiempo cuentan qué le pasó a un registro, pero
// no quién lo hizo ni desde dónde. Sin eso nadie puede responder "¿quién
// borró este cliente?", y en las compras de gobierno y sector financiero la
// trazabilidad de auditoría suele ser requisito de pliego, no un extra.
//
// Estas filas NO se editan ni se borran desde la aplicación: solo se
// insertan. Es lo que las hace valer como evidencia.
model RegistroAuditoria {
  id            String   @id @default(uuid())
  // Quién. Se guardan copias del nombre/correo/rol además del id porque el
  // usuario puede cambiar de rol o ser dado de baja después, y el registro
  // debe seguir contando lo que era cierto EN SU MOMENTO.
  usuarioId     String?
  usuarioEmail  String?
  usuarioNombre String?
  usuarioRol    String?

  // Qué: CREAR | ACTUALIZAR | ELIMINAR | RESTAURAR | ELIMINAR_DEFINITIVO |
  //      INICIAR_SESION | INICIAR_SESION_FALLIDO | CAMBIAR_ROL | ...
  accion      String
  // Sobre qué: nombre del modelo ("Oportunidad", "Usuario") e id afectado.
  entidad     String
  entidadId   String?
  // Resumen legible, para que la pantalla de auditoría se entienda sin
  // tener que interpretar los JSON de abajo.
  descripcion String?

  // Estado antes y después del cambio. Los campos sensibles (contraseñas,
  // tokens, llaves de API) se quitan antes de guardar — ver lib/auditoria.ts.
  antes   Json?
  despues Json?

  ip        String?
  userAgent String?
  creadoEn  DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, creadoEn])
  @@index([tenantId, entidad, entidadId])
  @@index([tenantId, usuarioId])
  @@map("registros_auditoria")
}

// ---- Plantillas de cotización ----

model PlantillaCotizacion {
  id       String   @id @default(uuid())
  nombre   String
  notas    String?
  creadoEn DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  items ItemPlantillaCotizacion[]

  @@index([tenantId])
  @@map("plantillas_cotizacion")
}

model ItemPlantillaCotizacion {
  id          String  @id @default(uuid())
  descripcion String
  cantidad    Int     @default(1)
  precioUnit  Decimal @db.Decimal(12, 2)

  plantillaId String
  plantilla   PlantillaCotizacion @relation(fields: [plantillaId], references: [id], onDelete: Cascade)

  @@index([plantillaId])
  @@map("items_plantilla_cotizacion")
}

// ---- Catálogo de servicios/productos ----

model Producto {
  id          String   @id @default(uuid())
  nombre      String
  descripcion String?
  precioBase  Decimal  @db.Decimal(12, 2)
  activo      Boolean  @default(true)
  creadoEn    DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("productos")
}

// ---- Metas de ventas ----

model MetaVenta {
  id            String   @id @default(uuid())
  anio          Int
  mes           Int? // null = meta anual
  valorObjetivo Decimal  @db.Decimal(12, 2)
  creadoEn      DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, anio, mes])
  @@index([tenantId])
  @@map("metas_venta")
}

// ---- Metas por vendedor ----

model MetaVendedor {
  id       String   @id @default(uuid())
  anio     Int
  mes      Int
  meta     Decimal  @db.Decimal(14, 2)
  creadoEn DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId  String
  usuario Usuario @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, anio, mes])
  @@index([tenantId])
  @@map("metas_vendedor")
}

// ---- Timeline de eventos por cliente ----

model EventoTimeline {
  id          String   @id @default(uuid())
  tipo        String // NOTA | LLAMADA | EMAIL | REUNION | WHATSAPP
  titulo      String
  descripcion String?
  creadoEn    DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  empresaId String?
  empresa   Empresa? @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  contactoId String?
  contacto   Contacto? @relation(fields: [contactoId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([empresaId])
  @@map("eventos_timeline")
}

// ---- Expedientes (módulo opcional — despachos de abogados) ----

enum EstadoExpediente {
  ACTIVO
  ARCHIVADO
  GANADO
  PERDIDO
}

enum EstadoTermino {
  PENDIENTE
  CUMPLIDO
  VENCIDO
}

model Expediente {
  id             String           @id @default(uuid())
  numeroRadicado String
  juzgado        String?
  tipoProceso    String?
  contraparte    String
  estado         EstadoExpediente @default(ACTIVO)
  notas          String?
  creadoEn       DateTime         @default(now())
  creadoBy       String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  empresaId String?
  empresa   Empresa? @relation(fields: [empresaId], references: [id], onDelete: SetNull)

  terminos       TerminoExpediente[]
  bitacora       EventoExpediente[]
  registrosHoras RegistroHoras[]

  @@unique([tenantId, numeroRadicado])
  @@index([tenantId])
  @@index([tenantId, creadoEn])
  @@index([empresaId])
  @@map("expedientes")
}

model TerminoExpediente {
  id          String        @id @default(uuid())
  descripcion String
  fechaLimite DateTime
  estado      EstadoTermino @default(PENDIENTE)
  notas       String?
  creadoEn    DateTime      @default(now())
  creadoBy    String?

  expedienteId String
  expediente   Expediente @relation(fields: [expedienteId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([expedienteId])
  @@index([tenantId])
  @@index([tenantId, estado, fechaLimite])
  @@map("terminos_expediente")
}

// Bitácora del expediente — mismo concepto que EventoTimeline, vocabulario legal.
model EventoExpediente {
  id          String   @id @default(uuid())
  tipo        String // AUDIENCIA | AUTO | ACTUACION | NOTA | LLAMADA | EMAIL | REUNION
  titulo      String
  descripcion String?
  creadoEn    DateTime @default(now())
  creadoBy    String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  expedienteId String
  expediente   Expediente @relation(fields: [expedienteId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([expedienteId])
  @@map("eventos_expediente")
}

model RegistroHoras {
  id          String   @id @default(uuid())
  fecha       DateTime
  horas       Decimal  @db.Decimal(5, 2)
  descripcion String?
  creadoEn    DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  expedienteId String
  expediente   Expediente @relation(fields: [expedienteId], references: [id], onDelete: Cascade)

  usuarioId String?
  usuario   Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([expedienteId])
  @@index([usuarioId])
  @@map("registros_horas")
}

// ---- Módulos opcionales (activables en Configuración) ----

enum CanalFuncion {
  PLATAFORMA
  TAQUILLA
  INVITADOS
  EMPRESA
}

model Funcion {
  id              String       @id @default(uuid())
  titulo          String
  fecha           DateTime
  sillasTotales   Int          @default(239)
  sillasVendidas  Int          @default(0)
  canal           CanalFuncion @default(PLATAFORMA)
  ingresoEstimado Decimal?     @db.Decimal(12, 2)
  notas           String?
  creadoEn        DateTime     @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  npsList     NpsRespuesta[]
  asistencias Asistencia[]

  @@index([tenantId])
  @@index([tenantId, fecha])
  @@map("funciones")
}

enum SegmentoEspectador {
  INDIVIDUAL
  GRUPO
  EMPRESA
  COLEGIO
}

enum NivelMembresia {
  ESPECTADOR
  FANATICO
  MECENAS
}

model Espectador {
  id             String             @id @default(uuid())
  nombre         String
  email          String?
  telefono       String?
  segmento       SegmentoEspectador @default(INDIVIDUAL)
  nivelMembresia NivelMembresia?
  notas          String?
  extras         Json?
  creadoEn       DateTime           @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  npsList     NpsRespuesta[]
  asistencias Asistencia[]

  @@index([tenantId])
  @@index([tenantId, creadoEn])
  @@map("espectadores")
}

// Registro de asistencia de un espectador a una función específica — es la
// pieza que faltaba para medir retención real (antes solo se inferían
// asistencias a partir de quién respondió la encuesta NPS, lo que subestima
// mucho la asistencia real ya que la mayoría no responde encuesta).
model Asistencia {
  id              String    @id @default(uuid())
  creadoEn        DateTime  @default(now())
  // Se marca cuando alguien hace clic en "Enviar por WhatsApp" en la cola de
  // NPS pendientes, para no repetir la solicitud a la misma persona.
  npsSolicitadoEn DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  funcionId String
  funcion   Funcion @relation(fields: [funcionId], references: [id], onDelete: Cascade)

  espectadorId String
  espectador   Espectador @relation(fields: [espectadorId], references: [id], onDelete: Cascade)

  @@unique([funcionId, espectadorId])
  @@index([tenantId])
  @@index([funcionId])
  @@index([espectadorId])
  @@map("asistencias")
}

model NpsRespuesta {
  id         String   @id @default(uuid())
  puntuacion Int
  comentario String?
  creadoEn   DateTime @default(now())

  funcionId String
  funcion   Funcion @relation(fields: [funcionId], references: [id], onDelete: Cascade)

  espectadorId String?
  espectador   Espectador? @relation(fields: [espectadorId], references: [id], onDelete: SetNull)

  @@index([funcionId])
  @@map("nps_respuestas")
}

// ---- Salones (módulo opcional — negocios de alquiler de espacios) ----

model Salon {
  id          String   @id @default(uuid())
  nombre      String
  capacidad   Int?
  descripcion String?
  activo      Boolean  @default(true)
  creadoEn    DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  cotizaciones  Cotizacion[]
  oportunidades Oportunidad[]

  @@index([tenantId])
  @@map("salones")
}
