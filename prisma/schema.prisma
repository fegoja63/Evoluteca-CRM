// Evoluteca CRM — Esquema de base de datos
// Sprint 1: Fundación y autenticación
// Los modelos de sprints futuros están comentados como referencia.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RolUsuario {
  ADMINISTRADOR
  GERENTE
  COMERCIAL
}

// Cada empresa cliente de Evoluteca es un "tenant" aislado.
// Todas las tablas de negocio (empresas, contactos, oportunidades...)
// llevan tenantId para garantizar separación de datos entre clientes.
model Tenant {
  id        String   @id @default(uuid())
  nombre    String
  slug      String   @unique
  plan      String   @default("arranque") // arranque | empresa | corporativo
  activo    Boolean  @default(true)
  creadoEn  DateTime @default(now())

  usuarios  Usuario[]
  empresas  Empresa[]
  contactos Contacto[]

  @@map("tenants")
}

model Usuario {
  id            String      @id @default(uuid())
  nombre        String
  email         String      @unique
  passwordHash  String
  rol           RolUsuario  @default(COMERCIAL)
  activo        Boolean     @default(true)
  creadoEn      DateTime    @default(now())

  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("usuarios")
}

model Empresa {
  id          String    @id @default(uuid())
  nombre      String
  sector      String?
  sitioWeb    String?
  telefono    String?
  notas       String?
  creadoEn    DateTime  @default(now())

  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactos   Contacto[]

  @@index([tenantId])
  @@map("empresas")
}

model Contacto {
  id          String    @id @default(uuid())
  nombre      String
  email       String?
  telefono    String?
  cargo       String?
  notas       String?
  creadoEn    DateTime  @default(now())

  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  empresaId   String?
  empresa     Empresa?  @relation(fields: [empresaId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@map("contactos")
}

