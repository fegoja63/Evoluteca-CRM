// Evoluteca CRM — Esquema de base de datos
// Sprint 1: Fundación y autenticación
// Los modelos de sprints futuros están comentados como referencia.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RolUsuario {
  ADMINISTRADOR
  GERENTE
  COMERCIAL
}

// Cada empresa cliente de Evoluteca es un "tenant" aislado.
// Todas las tablas de negocio (empresas, contactos, oportunidades...)
// llevan tenantId para garantizar separación de datos entre clientes.
model Tenant {
  id        String   @id @default(uuid())
  nombre    String
  slug      String   @unique
  plan      String   @default("arranque") // arranque | empresa | corporativo
  activo    Boolean  @default(true)
  creadoEn  DateTime @default(now())
  modulos   Json     @default("{}")

  usuarios      Usuario[]
  empresas      Empresa[]
  contactos     Contacto[]
  oportunidades Oportunidad[]
  actividades   Actividad[]
  cotizaciones  Cotizacion[]
  funciones     Funcion[]
  espectadores  Espectador[]

  @@map("tenants")
}

model Usuario {
  id            String      @id @default(uuid())
  nombre        String
  email         String      @unique
  passwordHash  String
  rol           RolUsuario  @default(COMERCIAL)
  activo        Boolean     @default(true)
  creadoEn      DateTime    @default(now())

  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("usuarios")
}

model Empresa {
  id          String    @id @default(uuid())
  nombre      String
  sector      String?
  sitioWeb    String?
  telefono    String?
  notas       String?
  extras      Json?
  creadoEn    DateTime  @default(now())

  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contactos     Contacto[]
  oportunidades Oportunidad[]
  actividades   Actividad[]
  cotizaciones  Cotizacion[]

  @@index([tenantId])
  @@map("empresas")
}

model Contacto {
  id          String    @id @default(uuid())
  nombre      String
  email       String?
  telefono    String?
  cargo       String?
  notas       String?
  extras      Json?
  creadoEn    DateTime  @default(now())

  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  segmento      String?   // INDIVIDUAL | GRUPO | EMPRESA | COLEGIO

  empresaId     String?
  empresa       Empresa?  @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  oportunidades Oportunidad[]
  actividades   Actividad[]

  @@index([tenantId])
  @@map("contactos")
}

enum EtapaOportunidad {
  PROSPECTO
  CALIFICADO
  PROPUESTA
  NEGOCIACION
  GANADA
  PERDIDA
}

model Oportunidad {
  id          String            @id @default(uuid())
  titulo      String
  valor       Decimal?          @db.Decimal(12, 2)
  etapa       EtapaOportunidad  @default(PROSPECTO)
  notas       String?
  extras      Json?
  creadoEn    DateTime          @default(now())

  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  empresaId   String?
  empresa     Empresa?          @relation(fields: [empresaId], references: [id], onDelete: SetNull)

  contactoId  String?
  contacto    Contacto?         @relation(fields: [contactoId], references: [id], onDelete: SetNull)
  actividades Actividad[]

  @@index([tenantId])
  @@map("oportunidades")
}

enum TipoActividad {
  LLAMADA
  REUNION
  TAREA
  EMAIL
}

model Actividad {
  id          String          @id @default(uuid())
  tipo        TipoActividad   @default(TAREA)
  titulo      String
  fecha       DateTime
  completada  Boolean         @default(false)
  notas       String?
  creadoEn    DateTime        @default(now())

  tenantId    String
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  empresaId     String?
  empresa       Empresa?      @relation(fields: [empresaId], references: [id], onDelete: SetNull)

  contactoId    String?
  contacto      Contacto?     @relation(fields: [contactoId], references: [id], onDelete: SetNull)

  oportunidadId String?
  oportunidad   Oportunidad?  @relation(fields: [oportunidadId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@map("actividades")
}

enum EstadoCotizacion {
  BORRADOR
  ENVIADA
  ACEPTADA
  RECHAZADA
}

model Cotizacion {
  id          String            @id @default(uuid())
  numero      Int               @default(autoincrement())
  estado      EstadoCotizacion  @default(BORRADOR)
  notas       String?
  creadoEn    DateTime          @default(now())

  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  empresaId   String?
  empresa     Empresa?          @relation(fields: [empresaId], references: [id], onDelete: SetNull)

  items       ItemCotizacion[]

  @@index([tenantId])
  @@map("cotizaciones")
}

model ItemCotizacion {
  id            String      @id @default(uuid())
  descripcion   String
  cantidad      Int         @default(1)
  precioUnit    Decimal     @db.Decimal(12, 2)

  cotizacionId  String
  cotizacion    Cotizacion  @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)

  @@index([cotizacionId])
  @@map("items_cotizacion")
}

// ---- Módulos opcionales (activables en Configuración) ----

enum CanalFuncion {
  PLATAFORMA
  TAQUILLA
  INVITADOS
  EMPRESA
}

model Funcion {
  id              String        @id @default(uuid())
  titulo          String
  fecha           DateTime
  sillasTotales   Int           @default(239)
  sillasVendidas  Int           @default(0)
  canal           CanalFuncion  @default(PLATAFORMA)
  ingresoEstimado Decimal?      @db.Decimal(12, 2)
  notas           String?
  creadoEn        DateTime      @default(now())

  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  npsList         NpsRespuesta[]

  @@index([tenantId])
  @@map("funciones")
}

enum SegmentoEspectador {
  INDIVIDUAL
  GRUPO
  EMPRESA
  COLEGIO
}

model Espectador {
  id          String              @id @default(uuid())
  nombre      String
  email       String?
  telefono    String?
  segmento    SegmentoEspectador  @default(INDIVIDUAL)
  notas       String?
  extras      Json?
  creadoEn    DateTime            @default(now())

  tenantId    String
  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  npsList     NpsRespuesta[]

  @@index([tenantId])
  @@map("espectadores")
}

model NpsRespuesta {
  id            String      @id @default(uuid())
  puntuacion    Int
  comentario    String?
  creadoEn      DateTime    @default(now())

  funcionId     String
  funcion       Funcion     @relation(fields: [funcionId], references: [id], onDelete: Cascade)

  espectadorId  String?
  espectador    Espectador? @relation(fields: [espectadorId], references: [id], onDelete: SetNull)

  @@index([funcionId])
  @@map("nps_respuestas")
}
