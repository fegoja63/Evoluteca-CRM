# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# respaldos de base de datos (datos reales de clientes, nunca a git)
/backups

# local env files
.env
.env.local
.env.development
.env.production
.env.test
.env.backup
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# Red de seguridad: cualquier .env queda fuera de git por defecto (lo agrego
# el CLI de Vercel). La plantilla de ejemplo si debe versionarse — no lleva
# credenciales, solo los nombres de las variables.
.env*
!.env.example
